# Auth.js — required in production; any long random string locally
AUTH_SECRET=

# Postgres (Neon). Required for app, scripts, and Drizzle CLI.
# Neon dashboard → connection string → use the pooled URL for serverless (ends with pooler or ?sslmode=require).
# Tip: create a "development" branch in Neon for local dev; production/preview on Vercel each need their own DATABASE_URL.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Demo user password when running npm run db:seed (default: buddy-dev-1)
SEED_DEMO_PASSWORD=
