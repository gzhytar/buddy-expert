# Auth.js — required in production; any long random string locally
AUTH_SECRET=

# SQLite database file for local dev (default: ./data/buddy.db)
DATABASE_URL=file:./data/buddy.db

# Production on Vercel: use Neon Postgres connection string, e.g.
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Swap drivers (pg / @neondatabase/serverless) and re-run Drizzle migrations for Postgres before go-live.

# Demo user password used when running npm run db:seed (default: buddy-dev-1)
SEED_DEMO_PASSWORD=
